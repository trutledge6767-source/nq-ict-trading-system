//@version=6
// =====================================================================
// NQ Intraday Mean-Reversion Sleeve — v1.0  (companion to P5 breakout)
// Fade price >k*ATR from the intraday SMA; passive LIMIT entry; 0.5*ATR stop;
// target = the mean; time-stop; flat by RTH close. Funded survival sizing.
//
// ALERTING (2026-06-26): webhooks fire on ACTUAL ORDER FILLS via alert_message
// on every order (limit entry + every exit). The TV alert must be a STRATEGY
// alert set to "Order fills" (NOT "alert() function calls only"). The stop level
// is set on fill via the reliable strategy.opentrades counter (not a position-
// change check). {{strategy.order.price}} = the real fill price. Same JSON the
// forward logger already parses.
// =====================================================================
strategy("NQ Mean-Reversion sleeve v1.0", overlay=true, pyramiding=0,
     default_qty_type=strategy.fixed, default_qty_value=1, initial_capital=50000,
     commission_type=strategy.commission.cash_per_contract, commission_value=2.10,
     slippage=1, calc_on_every_tick=false)

grpS = "Session (ET)"
rthSess = input.session("0930-1600", "RTH session", group=grpS)
cutoffH = input.int(15, "No new entries after hour (ET)", minval=0, maxval=16, group=grpS)

grpSig = "Mean-reversion signal"
maLen    = input.int(20,   "Mean SMA length", minval=2, group=grpSig)
kBand    = input.float(2.0, "Fade beyond k*ATR from mean", step=0.25, minval=0.5, group=grpSig)
entryOff = input.float(0.25,"Limit offset beyond signal (xATR) [0.25 = best]", step=0.25, minval=0.0, group=grpSig)
fillWin  = input.int(3,    "Cancel unfilled limit after N bars", minval=1, group=grpSig)

grpR = "Risk / Sizing"
atrLen     = input.int(14, "ATR length", group=grpR)
stopExtra  = input.float(0.5, "Stop distance (xATR) [0.5 mandatory]", step=0.25, minval=0.25, group=grpR)
maxBars    = input.int(15, "Time-stop (bars in trade)", minval=2, group=grpR)
riskPct    = input.float(0.07, "Risk % equity / trade [~0.7x of P5 = risk parity; size SMALL]", step=0.005, group=grpR)/100.0
pointValue = input.float(20.0, "$ per point (NQ=20, MNQ=2 — use MNQ for funded)", group=grpR)
maxContracts = input.int(10, "Max contracts cap", minval=1, group=grpR)

grpG = "Risk governor"
maxTradesD = input.int(8, "Max trades per day", minval=1, group=grpG)
dailyLossR = input.float(3.0, "Daily loss limit (R)", step=0.5, group=grpG)

// ---------- session / indicators ----------
inRTH  = not na(time(timeframe.period, rthSess, "America/New_York"))
etH    = hour(time, "America/New_York")
etMin  = etH*60 + minute(time, "America/New_York")
tfMin  = timeframe.in_seconds(timeframe.period)/60
lastBar = inRTH and (etMin + tfMin >= 16*60)
newRTH  = inRTH and not inRTH[1]
sma = ta.sma(close, maLen)
atr = ta.atr(atrLen)

// ---------- governor state ----------
var int tradesToday = 0
var float dayStartEq = strategy.equity
if newRTH
    tradesToday := 0
    dayStartEq := strategy.equity
riskUsdPerR = stopExtra*atr*pointValue
dayLossHit = (dayStartEq - strategy.equity) >= dailyLossR*riskUsdPerR
canSig = inRTH and etH < cutoffH and not lastBar and strategy.position_size == 0 and tradesToday < maxTradesD and not dayLossHit and not na(sma) and not na(atr)

overbought = close > sma + kBand*atr      // fade SHORT
oversold   = close < sma - kBand*atr      // fade LONG

calcQty(stopDist) =>
    rawRisk = stopDist*pointValue
    q = rawRisk > 0 ? math.floor((strategy.equity*riskPct)/rawRisk) : 0
    math.max(1, math.min(maxContracts, q))

closeMsg = '{"action":"close","symbol":"' + syminfo.ticker + '","price":{{strategy.order.price}}}'

// ---------- passive LIMIT entries (order-fill alert on the entry) ----------
var int pendSince = na
if strategy.position_size == 0
    qty = calcQty(stopExtra*atr)
    if overbought and canSig
        lim = close + entryOff*atr
        strategy.entry("R", strategy.short, qty=qty, limit=lim, alert_message='{"action":"entry","side":"short","symbol":"' + syminfo.ticker + '","price":{{strategy.order.price}},"sl":' + str.tostring(lim + stopExtra*atr) + '}')
        pendSince := bar_index
    else if oversold and canSig
        lim = close - entryOff*atr
        strategy.entry("R", strategy.long, qty=qty, limit=lim, alert_message='{"action":"entry","side":"long","symbol":"' + syminfo.ticker + '","price":{{strategy.order.price}},"sl":' + str.tostring(lim - stopExtra*atr) + '}')
        pendSince := bar_index
    else if not na(pendSince) and (bar_index - pendSince) >= fillWin
        strategy.cancel("R")
        pendSince := na

// ---------- on FILL (reliable opentrades counter): set stop level + time-stop anchor ----------
var float eStop = na
var int   eBar  = na
var int   prevOpenRev = 0
if strategy.opentrades > prevOpenRev
    eBar := bar_index
    eStop := strategy.position_size > 0 ? strategy.position_avg_price - stopExtra*atr : strategy.position_avg_price + stopExtra*atr
    pendSince := na
    tradesToday += 1
prevOpenRev := strategy.opentrades

// ---------- exits (order-fill alert on every exit) ----------
if strategy.position_size != 0 and not na(eStop)
    strategy.exit("X", from_entry="R", stop=eStop, limit=sma, alert_message=closeMsg)   // stop OR revert-to-mean target
    if bar_index - eBar >= maxBars
        strategy.close("R", comment="time-stop", alert_message=closeMsg)

if lastBar and strategy.position_size != 0
    strategy.close("R", comment="EOD flat", alert_message=closeMsg)

// ---------- plots ----------
plot(inRTH ? sma : na, "Mean (SMA)", color=color.new(color.gray,0))
plot(inRTH ? sma + kBand*atr : na, "Upper band", color=color.new(color.red,40))
plot(inRTH ? sma - kBand*atr : na, "Lower band", color=color.new(color.green,40))
plotshape(oversold and canSig,  "fade long",  shape.triangleup,   location.belowbar, color.lime, size=size.tiny)
plotshape(overbought and canSig, "fade short", shape.triangledown, location.abovebar, color.red,  size=size.tiny)
bgcolor(inRTH ? color.new(color.blue,95) : na)
