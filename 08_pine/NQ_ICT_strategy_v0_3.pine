//@version=6
// =====================================================================
// NQ ICT A+ Strategy — v0.3  (PRODUCTION INTEGRATION)
// Adds vs v0.2:
//   (A) News blackout: recurring 08:30 / 10:00 ET windows + FOMC/CPI/NFP date inputs
//   (B) Full risk governor: fixed-fractional vol-adjusted sizing, daily & weekly
//       loss limits, 3-consecutive-loss lockout
//   (C) Webhook automation: alertcondition() flags + alert() JSON payloads
// NON-REPAINTING: confirmed pivots, closed-bar FVGs, lookahead_off HTF,
//   process_orders_on_close=true, all events evaluated on bar close.
// =====================================================================
strategy("NQ ICT A+ v0.3", overlay=true, pyramiding=0,
     default_qty_type=strategy.fixed, default_qty_value=1,
     initial_capital=50000, commission_type=strategy.commission.cash_per_contract,
     commission_value=2.10, slippage=2, calc_on_every_tick=false,
     process_orders_on_close=true)

// ---------------- Inputs ----------------
grpKZ   = "Session / Killzone (ET)"
useKZ   = input.bool(true,  "Use NY AM killzone filter", group=grpKZ)
kzStart = input.int(7,  "KZ start hour (ET)", minval=0, maxval=23, group=grpKZ)
kzEnd   = input.int(11, "KZ end hour (ET)",   minval=0, maxval=23, group=grpKZ)

grpStr  = "Structure / Pivots"
pivLen  = input.int(5,  "Pivot lookback (L=R bars)", minval=2, group=grpStr)
seqWin  = input.int(12, "Sequence window (bars)",    minval=2, group=grpStr)

grpFVG  = "FVG"
useFVG     = input.bool(true,  "Require recent FVG", group=grpFVG)
fvgAtrMin  = input.float(0.20, "Min FVG size (xATR)", step=0.05, group=grpFVG)
fvgWin     = input.int(4, "FVG recency (bars)", minval=1, group=grpFVG)

grpSweep = "Liquidity Sweep"
useSweep   = input.bool(true, "Require recent liquidity sweep", group=grpSweep)
sweepLook  = input.int(20, "Sweep lookback bars", minval=5, group=grpSweep)

grpFib  = "Premium/Discount"
useFib  = input.bool(true, "Discount longs / premium shorts only", group=grpFib)

grpBias = "HTF Bias"
useBias = input.bool(true, "Use daily bias filter", group=grpBias)

grpNews = "News Blackout (ET)"
useNews   = input.bool(true, "Enable news blackout", group=grpNews)
nb0830    = input.bool(true, "Block 08:30 cluster (CPI/PPI/NFP/Claims)", group=grpNews)
nb1000    = input.bool(true, "Block 10:00 cluster (ISM/ConsConf)", group=grpNews)
preMin    = input.int(3,  "Pre-event block (min)",  minval=0, group=grpNews)
postMin   = input.int(15, "Post-event block (min)", minval=0, group=grpNews)
isFomcDay = input.bool(false, "TODAY is FOMC day (wide 13:55-14:45 block)", group=grpNews)

grpRisk = "Risk"
atrLen      = input.int(14, "ATR length", group=grpRisk)
stopAtrMlt  = input.float(1.5, "Stop buffer (xATR)", step=0.1, group=grpRisk)
rr          = input.float(2.0, "Reward:Risk target", step=0.25, group=grpRisk)
riskPct     = input.float(0.5, "Risk % equity / trade", step=0.1, group=grpRisk) / 100.0
maxContracts= input.int(10, "Max contracts cap", minval=1, group=grpRisk)
maxTradesD  = input.int(3, "Max trades per day", minval=1, group=grpRisk)
dailyLossR  = input.float(2.0, "Daily loss limit (R)", step=0.5, group=grpRisk)
weeklyLossR = input.float(4.0, "Weekly loss limit (R)", step=0.5, group=grpRisk)
maxConsecL  = input.int(3, "Consecutive-loss lockout", minval=1, group=grpRisk)
pointValue  = input.float(20.0, "$ per point (NQ=20)", group=grpRisk)

// ---------------- Core series ----------------
atr = ta.atr(atrLen)

dOpen = request.security(syminfo.tickerid, "D", open,  lookahead=barmerge.lookahead_off)
pdH   = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
pdL   = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_off)
biasLong  = not useBias or (close > dOpen and close > pdL)
biasShort = not useBias or (close < dOpen and close < pdH)

inKZ = not useKZ or not na(time(timeframe.period,
     str.format("{0,number,00}00-{1,number,00}00", kzStart, kzEnd), "America/New_York"))

// ---- News blackout (ET minutes-of-day) ----
etH = hour(time, "America/New_York")
etM = minute(time, "America/New_York")
etMin = etH * 60 + etM
inWin(evMin) => etMin >= evMin - preMin and etMin <= evMin + postMin
blackout = useNews and ( (nb0830 and inWin(8*60+30)) or (nb1000 and inWin(10*60)) or (isFomcDay and etMin >= 13*60+55 and etMin <= 14*60+45) )

// Confirmed pivots
ph = ta.pivothigh(high, pivLen, pivLen)
pl = ta.pivotlow(low,  pivLen, pivLen)
var float lastPH = na
var float lastPL = na
if not na(ph)
    lastPH := ph
if not na(pl)
    lastPL := pl

rngHi = ta.highest(high, sweepLook)
rngLo = ta.lowest(low,  sweepLook)
fibMid = (rngHi + rngLo) / 2.0
inDiscount = close < fibMid
inPremium  = close > fibMid

bullFVG = (low > high[2]) and ((low - high[2]) >= fvgAtrMin * atr)
bearFVG = (high < low[2]) and ((low[2] - high) >= fvgAtrMin * atr)

prevHigh = ta.highest(high[1], sweepLook)
prevLow  = ta.lowest(low[1],  sweepLook)
sweptHi = high > prevHigh and close < prevHigh
sweptLo = low  < prevLow  and close > prevLow

mssUpEvent   = not na(lastPH) and close > lastPH and close[1] <= lastPH
mssDownEvent = not na(lastPL) and close < lastPL and close[1] >= lastPL

bsSweepLo = ta.barssince(sweptLo)
bsSweepHi = ta.barssince(sweptHi)
bsBullF   = ta.barssince(bullFVG)
bsBearF   = ta.barssince(bearFVG)
sweepLoRecent = bsSweepLo <= seqWin
sweepHiRecent = bsSweepHi <= seqWin
bullFvgRecent = bsBullF <= fvgWin
bearFvgRecent = bsBearF <= fvgWin

longSetup  = biasLong  and inKZ and not blackout and mssUpEvent   and (not useSweep or sweepLoRecent) and (not useFVG or bullFvgRecent) and (not useFib or inDiscount)
shortSetup = biasShort and inKZ and not blackout and mssDownEvent and (not useSweep or sweepHiRecent) and (not useFVG or bearFvgRecent) and (not useFib or inPremium)

// ---------------- Risk governor ----------------
var int   tradesToday = 0
var int   consecL     = 0
var bool  locked      = false
var float dayStartEq  = strategy.equity
var float weekStartEq = strategy.equity
newDay  = ta.change(time("D")) != 0
newWeek = ta.change(time("W")) != 0
if newDay
    tradesToday := 0
    dayStartEq  := strategy.equity
    locked      := false
if newWeek
    weekStartEq := strategy.equity

riskPerTradeUsd = stopAtrMlt * atr * pointValue
dayLossHit  = (dayStartEq  - strategy.equity) >= dailyLossR  * riskPerTradeUsd
weekLossHit = (weekStartEq - strategy.equity) >= weeklyLossR * riskPerTradeUsd
canTrade = tradesToday < maxTradesD and not dayLossHit and not weekLossHit and not locked

// detect closed-trade result to update streak / lockout
var int lastClosed = 0
if strategy.closedtrades > lastClosed
    if strategy.closedtrades.profit(strategy.closedtrades - 1) < 0
        consecL += 1
    else
        consecL := 0
    if consecL >= maxConsecL
        locked := true
    lastClosed := strategy.closedtrades

// position sizing: fixed-fractional, vol-adjusted, capped
calcQty(stopDist) =>
    rawRisk = stopDist * pointValue
    q = rawRisk > 0 ? math.floor((strategy.equity * riskPct) / rawRisk) : 0
    math.max(1, math.min(maxContracts, q))

// ---------------- Orders + webhook alerts ----------------
var string sideTag = ""
if longSetup and canTrade and strategy.position_size == 0
    stopPx = math.min(low, low[1]) - stopAtrMlt * atr
    risk   = close - stopPx
    if risk > 0
        qty = calcQty(risk)
        tgt = close + rr * risk
        strategy.entry("L", strategy.long, qty=qty)
        strategy.exit("Lx", "L", stop=stopPx, limit=tgt)
        tradesToday += 1
        alert('{"action":"entry","side":"long","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close) + ',"sl":' + str.tostring(stopPx) + ',"tp":' + str.tostring(tgt) + ',"qty":' + str.tostring(qty) + '}', alert.freq_once_per_bar_close)

if shortSetup and canTrade and strategy.position_size == 0
    stopPx = math.max(high, high[1]) + stopAtrMlt * atr
    risk   = stopPx - close
    if risk > 0
        qty = calcQty(risk)
        tgt = close - rr * risk
        strategy.entry("S", strategy.short, qty=qty)
        strategy.exit("Sx", "S", stop=stopPx, limit=tgt)
        tradesToday += 1
        alert('{"action":"entry","side":"short","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close) + ',"sl":' + str.tostring(stopPx) + ',"tp":' + str.tostring(tgt) + ',"qty":' + str.tostring(qty) + '}', alert.freq_once_per_bar_close)

// (alertcondition() is indicator-only; strategy uses alert() above for webhooks.
//  The companion INDICATOR build exposes alertcondition flags for alert-UI wiring.)

// ---------------- Visuals ----------------
plotshape(longSetup,  title="Long",  style=shape.triangleup,   location=location.belowbar, color=color.lime, size=size.tiny)
plotshape(shortSetup, title="Short", style=shape.triangledown, location=location.abovebar, color=color.red,  size=size.tiny)
bgcolor(inKZ ? color.new(color.blue, 92) : na, title="Killzone")
bgcolor(blackout ? color.new(color.orange, 80) : na, title="News blackout")
